# Set to "true" to use the in-memory mock API (no backend needed)
VITE_USE_MOCK=false

# Override API base if backend runs elsewhere (default: same-origin /api via Vite proxy)
# VITE_API_BASE=http://localhost:5050/api

# Vite dev proxy target for /api requests
VITE_API_PROXY_TARGET=http://localhost:5050
