PORT=5050
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173,https://shailsoft.github.io,https://shailsoft-videodownloader.onrender.com

# Path to yt-dlp binary (defaults to "yt-dlp" on PATH)
YTDLP_PATH=yt-dlp

# Optional: Netscape-format cookies.txt for YouTube bot/login checks.
# On Render, upload a Secret File named cookies.txt; the API auto-detects it at /etc/secrets/cookies.txt.
# YTDLP_COOKIES_FILE=/etc/secrets/cookies.txt
# YTDLP_COOKIES_B64=
# YTDLP_COOKIES_FROM_BROWSER=chrome

# Path to ffmpeg binary (defaults to "ffmpeg" on PATH)
FFMPEG_PATH=ffmpeg

# Hard cap on video duration (seconds) the API will accept. 0 disables the check.
MAX_DURATION_SECONDS=3600
